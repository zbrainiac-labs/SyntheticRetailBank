-- ============================================================
-- SCHEMA TESTS
-- ============================================================

-- Test: All 8 RAW schemas exist
SELECT COUNT(*) AS SCHEMA_COUNT FROM INFORMATION_SCHEMA.SCHEMATA WHERE CATALOG_NAME = 'AAA_DEV_SYNTHETIC_BANK' AND SCHEMA_NAME IN ('CRM_RAW_001', 'PAY_RAW_001', 'EQT_RAW_001', 'REF_RAW_001', 'FII_RAW_001', 'CMD_RAW_001', 'LOA_RAW_001', 'REP_RAW_001');
-- EXPECT: SCHEMA_COUNT = 8

-- Test: All 8 AGG schemas exist
SELECT COUNT(*) AS SCHEMA_COUNT FROM INFORMATION_SCHEMA.SCHEMATA WHERE CATALOG_NAME = 'AAA_DEV_SYNTHETIC_BANK' AND SCHEMA_NAME IN ('CRM_AGG_001', 'PAY_AGG_001', 'EQT_AGG_001', 'REF_AGG_001', 'FII_AGG_001', 'CMD_AGG_001', 'LOA_AGG_001', 'REP_AGG_001');
-- EXPECT: SCHEMA_COUNT = 8

